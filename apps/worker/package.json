{
  "name": "@changelens/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --format esm --sourcemap --clean",
    "clean": "rm -rf dist coverage storage",
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "lint": "eslint src",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@changelens/config": "workspace:*",
    "@changelens/contracts": "workspace:*",
    "@changelens/database": "workspace:*",
    "@changelens/queue": "workspace:*",
    "@changelens/scraper": "workspace:*",
    "@changelens/storage": "workspace:*",
    "bullmq": "5.80.3",
    "drizzle-orm": "0.45.2",
    "ioredis": "5.11.1",
    "pino": "10.3.1",
    "prom-client": "15.1.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.10",
    "tsup": "8.5.1",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
