{
  "name": "@changelens/config",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean && tsc -p tsconfig.json --declaration --emitDeclarationOnly --outDir dist --noEmit false",
    "clean": "rm -rf dist coverage",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "dependencies": {
    "zod": "4.4.3"
  },
  "devDependencies": {
    "tsup": "8.5.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
