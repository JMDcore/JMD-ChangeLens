NODE_ENV=development
LOG_LEVEL=info

# Public origins
WEB_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=/api
BACKEND_INTERNAL_URL=http://localhost:4000

# API
API_HOST=0.0.0.0
API_PORT=4000
COOKIE_SECURE=false
SESSION_TTL_DAYS=30
METRICS_TOKEN=development-metrics-token-change-me

# Data services
DATABASE_URL=postgresql://changelens:changelens@localhost:5432/changelens
REDIS_URL=redis://:changelens-dev@localhost:6379/0

# Object storage (LocalStack S3 in development)
S3_ENDPOINT=http://localhost:4566
S3_REGION=eu-west-1
S3_BUCKET=changelens-screenshots
S3_ACCESS_KEY_ID=test
S3_SECRET_ACCESS_KEY=test
S3_FORCE_PATH_STYLE=true

# Worker policy
CHANGELENS_USER_AGENT=ChangeLensBot/0.1 (+https://github.com/JMDcore/JMD-ChangeLens)
WORKER_CONCURRENCY=2
WORKER_HEALTH_PORT=4001
DOMAIN_MIN_DELAY_MS=2500
CRAWL_TIMEOUT_MS=30000
MAX_RESPONSE_BYTES=5242880
MAX_REDIRECTS=5
BROWSER_MEMORY_MB=512

# Webhook signatures. Generate a unique random value in production.
WEBHOOK_SIGNING_SECRET=development-only-change-me-please-use-at-least-32-characters

# Controlled portfolio mode for UI development without infrastructure.
NEXT_PUBLIC_DEMO_SNAPSHOT=false
